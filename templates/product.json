    "bb_faq_CBwVi8": {
      "type": "bb-faq",
      "name": "FAQ accordion (W4-04)",
      "settings": {
        "section_title": "Frequently Asked Questions",
        "subtitle": "",
        "background_color": "#ffffff",
        "brand_color": "#1a1a1a",
        "accent_color": "#cd241d",
        "q_1": "How fast will my gift arrive?",
        "a_1": "Orders placed by 5pm EST ship the same business day. Standard ground delivery typically arrives in 3–6 business days. Need it sooner? Express options are available at checkout.",
        "q_2": "Can I pick a specific delivery date?",
        "a_2": "Yes. At checkout you can choose any future date for delivery, so the gift shows up exactly when you want it to — birthday, anniversary, holiday, or just a Tuesday.",
        "q_3": "Do you include a personalized greeting card?",
        "a_3": "Every basket ships with a free personalized greeting card. You write the message during checkout and we hand-write or print it to include in the box.",
        "q_4": "What if my recipient isn't home when it's delivered?",
        "a_4": "Carriers will leave the package at the door unless an adult signature is required (alcohol-containing baskets always require this). For ID-required deliveries, the recipient gets up to 3 delivery attempts, then can pick up at the local carrier facility.",
        "q_5": "Can I add my own engraving or custom touches?",
        "a_5": "Yes — many of our baskets include engraved glass options, premium add-ons, and snack upgrades. Look for the customization options on the product page just below the basket details.",
        "q_6": "What happens if something arrives damaged?",
        "a_6": "We guarantee your gift arrives looking awesome. If anything is damaged, missing, or not right — email us with a photo and we'll fix it for free, no questions asked.",
        "q_7": "Where do you ship to?",
        "a_7": "All 50 US states. Some baskets containing alcohol have state-specific shipping restrictions — those will be flagged at checkout if your recipient's state can't receive the contents.",
        "q_8": "Are these baskets really made by hand?",
        "a_8": "Yes. Every basket is hand-built to order by our small team in Ventura, California — using real spirits, real snacks, and quality accessories. Nothing is mass-pre-assembled overseas."
      }
    },
