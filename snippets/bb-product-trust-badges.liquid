{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
BROBASKET PRODUCT TRUST BADGES
----------------------------------------------------------------------------------------------------------------------

Renders a row of trust/value-prop badges below Add to Cart.

Supported parameters (all from block.settings):
* badge_1_text … badge_4_text  – text for each badge row
* badge_1_icon … badge_4_icon  – icon key per row
{%- endcomment -%}

<div class="bb-trust-badges">
  {%- for i in (1..4) -%}
    {%- case i -%}
      {%- when 1 -%}
        {%- assign icon_key = badge_1_icon -%}
        {%- assign text = badge_1_text -%}
      {%- when 2 -%}
        {%- assign icon_key = badge_2_icon -%}
        {%- assign text = badge_2_text -%}
      {%- when 3 -%}
        {%- assign icon_key = badge_3_icon -%}
        {%- assign text = badge_3_text -%}
      {%- when 4 -%}
        {%- assign icon_key = badge_4_icon -%}
        {%- assign text = badge_4_text -%}
    {%- endcase -%}

    {%- if text != blank -%}
      <div class="bb-trust-badges__item">
        <span class="bb-trust-badges__icon" aria-hidden="true">
          {%- case icon_key -%}
            {%- when 'gift' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="8" width="18" height="4" rx="1"/>
                <path d="M12 8v13M3 12h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7z"/>
                <path d="M12 8C12 8 12 5 9.5 3.5S5 4 5 4s-1 2.5 1.5 4H12zM12 8c0 0 0-3 2.5-4.5S19 4 19 4s1 2.5-1.5 4H12z"/>
              </svg>
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 3h15v13H1zM16 8h4l3 4v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            {%- when 'calendar' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
            {%- when 'usa' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                <line x1="4" y1="22" x2="4" y2="3"/>
              </svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            {%- when 'check' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
          {%- endcase -%}
        </span>
        <span class="bb-trust-badges__text">{{ text }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<style>
  .bb-trust-badges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid rgb(var(--border-color, 229, 231, 235));
    border-radius: 12px;
    overflow: hidden;
    margin-top: 4px;
  }

  .bb-trust-badges__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid rgb(var(--border-color, 229, 231, 235));
    border-right: 1px solid rgb(var(--border-color, 229, 231, 235));
  }

  .bb-trust-badges__item:nth-child(2n) {
    border-right: none;
  }

  .bb-trust-badges__item:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .bb-trust-badges__item:nth-last-child(1):nth-child(2n+1) {
    border-right: none;
    grid-column: 1 / -1;
    justify-content: center;
  }

  .bb-trust-badges__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgb(var(--button-background, 0, 0, 0));
    color: rgb(var(--button-text-color, 255, 255, 255));
  }

  .bb-trust-badges__icon svg {
    width: 18px;
    height: 18px;
  }

  .bb-trust-badges__text {
    font-size: 12px;
    font-weight: 600;
    line-height: 1.35;
    color: rgb(var(--text-primary, 0, 0, 0));
  }

  @media screen and (max-width: 499px) {
    .bb-trust-badges {
      grid-template-columns: 1fr;
    }

    .bb-trust-badges__item {
      border-right: none !important;
    }

    .bb-trust-badges__item:last-child {
      border-bottom: none;
    }

    .bb-trust-badges__item:nth-last-child(1):nth-child(2n+1) {
      grid-column: auto;
      justify-content: flex-start;
    }
  }
</style>
