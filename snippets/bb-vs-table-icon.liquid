{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
BB-VS-TABLE-ICON snippet
Renders a single inline SVG by name. Used inside bb-vs-table.liquid.

Parameters:
  * name      — string from the section's icon select dropdowns
  * fallback  — name to use if `name` doesn't match anything

Icons available:
  BroBasket positive: ingredients, usa-flag, rocket, sparkle, thumbs-up, check-circle
  Generic negative:   junk-box, factory, snail, plain-box, people-shrug, x-circle

All icons sized 40×40 viewBox, stroke="currentColor" so the parent
.bb-vs-table__icon--us / --them controls colour.
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign icon_name = name | default: fallback | default: 'check-circle' -%}

{%- case icon_name -%}
  {%- when 'ingredients' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 13c0-3 3-5 6-5s5 2 5 5-2 5-5 5-6-2-6-5z"/>
      <path d="M14 8l4-4M16 4l2 2"/>
      <circle cx="9" cy="13" r="1.5" fill="currentColor"/>
    </svg>
  {%- when 'usa-flag' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="1"/>
      <path d="M3 9h18M3 13h18M3 17h18"/>
      <rect x="3" y="5" width="8" height="6" fill="currentColor" opacity="0.15"/>
      <path d="M16 14l2 2 4-4" stroke-width="2.2"/>
    </svg>
  {%- when 'rocket' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
      <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
      <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
      <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
    </svg>
  {%- when 'sparkle' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
      <circle cx="12" cy="12" r="3" fill="currentColor" opacity="0.2"/>
    </svg>
  {%- when 'thumbs-up' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M7 22V11M2 13v7a2 2 0 0 0 2 2h2V11H4a2 2 0 0 0-2 2zM15.5 22H18a2 2 0 0 0 2-2v-2.5l2-5.5a2 2 0 0 0-2-2.5h-5.5l1-4.5a2 2 0 0 0-2-2.5L9 9v13"/>
    </svg>
  {%- when 'check-circle' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="m8 12 3 3 5-6" stroke-width="2.2"/>
    </svg>
  {%- when 'junk-box' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 8l1.5 11a2 2 0 0 0 2 1.7h7a2 2 0 0 0 2-1.7L19 8z"/>
      <path d="M3 8h18"/>
      <path d="M9 11v7M12 11v7M15 11v7"/>
      <path d="M8 5l1-2h6l1 2"/>
    </svg>
  {%- when 'factory' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 21V11l5 3V11l5 3V11l5 3v7z"/>
      <path d="M3 21h18"/>
      <path d="M19 14V6l-2-2h-2v6"/>
      <circle cx="6" cy="17" r="0.8" fill="currentColor"/>
      <circle cx="11" cy="17" r="0.8" fill="currentColor"/>
      <circle cx="16" cy="17" r="0.8" fill="currentColor"/>
    </svg>
  {%- when 'snail' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="14" r="6"/>
      <circle cx="12" cy="14" r="3"/>
      <path d="M3 20h2a4 4 0 0 1 4-4"/>
      <path d="M18 12V8a2 2 0 0 1 2-2"/>
      <circle cx="20" cy="6" r="1" fill="currentColor"/>
    </svg>
  {%- when 'plain-box' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
      <path d="M3.3 7 12 12l8.7-5"/>
      <path d="M12 22V12"/>
    </svg>
  {%- when 'people-shrug' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="7" r="3"/>
      <path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
      <circle cx="17" cy="9" r="2.5"/>
      <path d="M14 21v-1a3 3 0 0 1 3-3h1a3 3 0 0 1 3 3v1"/>
    </svg>
  {%- when 'x-circle' -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="m15 9-6 6M9 9l6 6" stroke-width="2.2"/>
    </svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="m8 12 3 3 5-6" stroke-width="2.2"/>
    </svg>
{%- endcase -%}
