    {%- comment -%}
    ------------------------------------------------------------------------------------------------------------------------
    COMPREHENSIVE CONSOLE SUPPRESSION
    Silently handles all third-party app logs, blocked services, and non-critical errors
    Prevents console pollution while maintaining site functionality
    ------------------------------------------------------------------------------------------------------------------------
    {%- endcomment -%}
    <script>
      (function() {
        'use strict';
        
        // List of third-party domains and services to suppress
        // Last audited 2026-05-11: removed entries for apps no longer installed.
        const BLOCKED_DOMAINS = [
          'klaviyo.com',
          'static-tracking.klaviyo.com',
          'static.klaviyo.com',
          'shareasale.com',
          'beacon-v2.helpscout.net',
          '/api/collect',
          'web-pixel-',
          'judge.me',
          'cdnwidget.judge.me',
          'clarity.ms',
          'l.clarity.ms',
          'analytics.ahrefs.com',
          'd3hb14vkzrxvla.cloudfront.net'
        ];
        
        // Third-party app scripts to suppress logs from
        // Last audited 2026-05-11: removed entries for apps no longer installed.
        const APP_SCRIPTS = [
          'theme-hot-reload.js',
          'web-pixel-',
          'gbbMix',
          'judge.me'
        ];
        
        // Error patterns to suppress
        // Last audited 2026-05-11: removed patterns for uninstalled apps
        // (InCartUpsell, GiftBox/bbq-related, EB-old-syntax). Also removed
        // overly broad patterns that hid real issues:
        //   - "Not Found" / "502" / "503" / "Bad Gateway" (real 404s/5xxs matter)
        //   - "Failed to load resource" (real load failures matter)
        //   - "Unexpected token" / "is not valid JSON" (real JSON parse bugs matter)
        //   - "was preloaded using link preload but not used" (kept hidden a
        //     real Shopify Early Hints misuse — better to see and fix the
        //     underlying preload, not silence the warning)
        const SUPPRESS_PATTERNS = [
          'ERR_BLOCKED_BY_CLIENT',
          'net::ERR_BLOCKED_BY_CLIENT',
          'Unchecked runtime.lastError',
          'message port closed',
          'sandboxed environment',
          'addEventListener may not behave as expected',
          'HotReload',
          'CLI hot reload disabled',
          'gbbMixUtils',
          'Event: gbbMix',
          '?pb='
        ];
        
        // Check if message should be suppressed
        function shouldSuppress(message) {
          const msgStr = String(message).toLowerCase();
          
          // Check patterns (but be careful with generic terms like "object")
          for (let pattern of SUPPRESS_PATTERNS) {
            const patternLower = pattern.toLowerCase();
            // For generic terms like "object" or "array", only suppress if they appear to be debug logs
            if ((patternLower === 'object' || patternLower === 'array(') && msgStr === patternLower) {
              return true; // Just the word "object" or "array(" alone
            } else if (msgStr.includes(patternLower)) {
              return true;
            }
          }
          
          return BLOCKED_DOMAINS.some(domain => msgStr.includes(domain.toLowerCase())) ||
                 APP_SCRIPTS.some(script => msgStr.includes(script.toLowerCase()));
        }
        
        // Suppress console.error
        const originalConsoleError = console.error;
        console.error = function(...args) {
          const errorString = args.join(' ');
          if (shouldSuppress(errorString)) return;
          originalConsoleError.apply(console, args);
        };
        
        // Suppress console.warn
        const originalConsoleWarn = console.warn;
        console.warn = function(...args) {
          const warnString = args.join(' ');
          if (shouldSuppress(warnString)) return;
          originalConsoleWarn.apply(console, args);
        };
        
        // Suppress console.log from third-party apps
        const originalConsoleLog = console.log;
        console.log = function(...args) {
          const logString = args.join(' ');
          
          // Check stack trace for third-party apps
          try {
            const stack = new Error().stack;
            if (stack && APP_SCRIPTS.some(script => stack.includes(script))) {
              return; // Suppress third-party app logs
            }
          } catch (e) {
            // Continue if stack trace fails
          }
          
          // Suppress based on content patterns
          if (shouldSuppress(logString)) return;
          
          // Suppress debug logs that are just numbers or single words from apps
          if (args.length === 1 && (
            typeof args[0] === 'number' ||
            (typeof args[0] === 'string' && args[0].length < 50 && /^[0-9]+$/.test(args[0]))
          )) {
            return; // Likely debug counter
          }
          
          // Suppress array/object debug logs that look like app debugging
          if (args.length <= 2 && args.some(arg => 
            (Array.isArray(arg) || (typeof arg === 'object' && arg !== null))
          )) {
            try {
              const stack = new Error().stack;
              // If it's from an inline script (contains ?pb=0 or similar), suppress it
              if (stack && (stack.includes('?pb=') || stack.includes('craft-sampler') || stack.includes('product'))) {
                return;
              }
            } catch (e) {
              // Continue
            }
          }
          
          originalConsoleLog.apply(console, args);
        };
        
        // Handle XMLHttpRequest errors for blocked services
        const originalXHRSend = XMLHttpRequest.prototype.send;
        XMLHttpRequest.prototype.send = function(...args) {
          const xhr = this;
          const originalOnError = xhr.onerror;
          const originalOnReadyStateChange = xhr.onreadystatechange;
          
          xhr.onerror = function(e) {
            const url = xhr.responseURL || '';
            if (BLOCKED_DOMAINS.some(domain => url.includes(domain))) {
              return; // Silently ignore blocked requests
            }
            if (originalOnError) originalOnError.apply(this, arguments);
          };
          
          xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status === 0) {
              const url = xhr.responseURL || '';
              if (BLOCKED_DOMAINS.some(domain => url.includes(domain))) {
                return; // Silently ignore blocked requests
              }
            }
            if (originalOnReadyStateChange) originalOnReadyStateChange.apply(this, arguments);
          };
          
          try {
            return originalXHRSend.apply(this, args);
          } catch (e) {
            const url = xhr.responseURL || '';
            if (!BLOCKED_DOMAINS.some(domain => url.includes(domain))) {
              throw e; // Re-throw if not a blocked domain
            }
          }
        };
        
        // Handle fetch errors for blocked services
        const originalFetch = window.fetch;
        window.fetch = function(...args) {
          const url = args[0] ? args[0].toString() : '';
          
          return originalFetch.apply(this, args).catch(error => {
            if (BLOCKED_DOMAINS.some(domain => url.includes(domain))) {
              // Return a fake successful response for blocked domains
              return new Response(null, { status: 200, statusText: 'OK' });
            }
            throw error; // Re-throw if not a blocked domain
          });
        };
        
        // Suppress unhandled promise rejections for blocked services
        // NOTE: Do NOT suppress generic 'Failed to fetch' — that matches
        // cart/add.js failures and silently swallows real checkout errors.
        window.addEventListener('unhandledrejection', function(event) {
          const reason = event.reason ? event.reason.toString() : '';
          const isBlockedDomain = BLOCKED_DOMAINS.some(domain => reason.toLowerCase().includes(domain.toLowerCase()));
          if (isBlockedDomain || shouldSuppress(reason)) {
            event.preventDefault();
            return;
          }
        });
        
        // Suppress resource loading errors (network tab errors that appear in console)
        window.addEventListener('error', function(event) {
          const target = event.target || event.srcElement;
          
          // Check if it's a resource loading error
          if (target && (target.tagName === 'SCRIPT' || target.tagName === 'LINK' || target.tagName === 'IMG')) {
            const src = target.src || target.href || '';
            
            if (BLOCKED_DOMAINS.some(domain => src.includes(domain)) || 
                APP_SCRIPTS.some(script => src.includes(script))) {
              event.preventDefault();
              event.stopPropagation();
              return false;
            }
          }
          
          // Suppress based on error message
          const errorMsg = event.message || '';
          if (shouldSuppress(errorMsg)) {
            event.preventDefault();
            event.stopPropagation();
            return false;
          }
        }, true);
        
        // Create safe script loader helper
        window.loadScriptSafely = function(src, options = {}) {
          return new Promise((resolve) => {
            const script = document.createElement('script');
            script.src = src;
            script.async = options.async !== false;
            script.defer = options.defer || false;
            
            script.onload = () => resolve(true);
            script.onerror = () => {
              // Silently fail for third-party scripts
              if (BLOCKED_DOMAINS.some(domain => src.includes(domain))) {
                resolve(false);
              } else {
                console.warn('Failed to load script:', src);
                resolve(false);
              }
            };
            
            (options.target || document.body).appendChild(script);
          });
        };
      })();
    </script>

    {%- comment -%}
    ------------------------------------------------------------------------------------------------------------------------
    HELP SCOUT BEACON — DEFERRED LOAD (2026-05-11)

    Help Scout's standard embed loads ~50KB of JS on every page via
    window.onload. We defer it until first user interaction (scroll,
    click, touch, keydown) OR 8 seconds idle, whichever comes first.
    Customers reaching for chat are doing so intentionally — they'll
    interact with the page before needing the beacon.

    Help Scout app embed has been toggled OFF in Shopify Admin so this
    is the only place Beacon loads. The standard window.Beacon stub
    is defined synchronously so any other code referencing Beacon()
    queues calls until the real script loads.
    ------------------------------------------------------------------------------------------------------------------------
    {%- endcomment -%}
    <script>
      (function (w, d) {
        // Define stub Beacon queue function immediately
        w.Beacon = function (method, options, data) {
          w.Beacon.readyQueue.push({ method: method, options: options, data: data });
        };
        w.Beacon.readyQueue = [];

        // Queue the init call — real beacon.js will process this queue once loaded
        w.Beacon('init', '094650dc-9f67-482d-b84f-306d434284f9');

        // Move Beacon to bottom-left so it doesn't collide with the floating
        // ATC bar on PDPs (which lives bottom-right). Uses Help Scout's
        // documented JS config API rather than CSS, which is class-name
        // fragile. CSS in bb-cro-overrides.css still handles the vertical
        // offset that lifts the beacon above the ADA accessibility widget.
        // Help Scout docs: https://developer.helpscout.com/beacon-2/web/javascript-api/#configuration
        w.Beacon('config', { display: { position: 'left' } });

        var loaded = false;
        function loadBeacon() {
          if (loaded) return;
          loaded = true;
          var script = d.createElement('script');
          script.type = 'text/javascript';
          script.async = true;
          script.src = 'https://beacon-v2.helpscout.net';
          var first = d.getElementsByTagName('script')[0];
          first.parentNode.insertBefore(script, first);
        }

        // Triggers: first user interaction OR 8s timeout
        var interactionEvents = ['mousedown', 'touchstart', 'keydown', 'scroll'];
        function onInteraction() {
          interactionEvents.forEach(function (ev) {
            d.removeEventListener(ev, onInteraction);
          });
          loadBeacon();
        }
        interactionEvents.forEach(function (ev) {
          d.addEventListener(ev, onInteraction, { once: true, passive: true });
        });
        setTimeout(loadBeacon, 8000);
      })(window, document);
    </script>

    {%- comment -%}
    ------------------------------------------------------------------------------------------------------------------------
    MICROSOFT CLARITY — DEFERRED LOAD (2026-05-11)

    Clarity records session replays and heatmaps. We don't need it firing
    on the critical render path. Defer to requestIdleCallback so it loads
    only after the browser is idle (~3-5s after page load, typically).
    Fallback to setTimeout for browsers without requestIdleCallback
    support (Safari pre-15.4).

    Clarity app embed has been toggled OFF in Shopify Admin so this is
    the only place Clarity loads.

    Project ID: REPLACE_WITH_BOUNTY_CLARITY_ID
    Tradeoff: misses the first ~3-5s of session recording. Acceptable
    because most user behavior we want to see (interactions, scrolls,
    clicks) happens after initial paint anyway.
    ------------------------------------------------------------------------------------------------------------------------
    {%- endcomment -%}
    <script>
      (function (w, d) {
        function loadClarity() {
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
          })(w, d, "clarity", "script", "REPLACE_WITH_BOUNTY_CLARITY_ID");
        }

        // Defer until browser is idle (after critical render complete).
        // Modern browsers: requestIdleCallback, max 4s timeout fallback.
        // Older browsers: plain setTimeout at 3s.
        if ('requestIdleCallback' in w) {
          w.requestIdleCallback(loadClarity, { timeout: 4000 });
        } else {
          setTimeout(loadClarity, 3000);
        }
      })(window, document);
    </script>

