{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
BROBASKET COMPARISON TABLE (W4-02) — "BroBasket vs the Generic Gift"
----------------------------------------------------------------------------------------------------------------------

Two-column comparison section that mirrors James's existing US-vs-them
graphic so the on-page version reads as one consistent brand voice with
the share-graphic version.

Row anatomy (5 rows by default):
   [BroBasket icon + statement]   |  [Category label]  |  [Generic icon + statement]

Five category rows seeded as defaults:
  1. Food & Ingredients     — Real ingredients vs. stale no-name junk
  2. Made to Order          — Hand-made in USA vs. mass-assembled overseas
  3. Speed & Fulfillment    — Ships same day vs. slow processing
  4. Personalization        — Personalized & customized vs. one-size-fits-all
  5. Recipient Experience   — Curated for "bros" vs. generic & predictable

Layout:
  * Desktop: 3-column row with center label, BroBasket left, Generic right
  * Mobile:  Stacks per row — BroBasket card, then label, then Generic card

Icons rendered as inline SVGs (same pattern as bb-guarantee-strip).
A green check overlay is added to BroBasket icons; an X overlay to Generic.
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign bg_color    = section.settings.background_color | default: '#fdf9f1' -%}
{%- assign brand_color = section.settings.brand_color      | default: '#1a1a1a' -%}
{%- assign accent_red  = section.settings.accent_color     | default: '#cd241d' -%}

<section
  class="bb-vs-table"
  style="--bb-vs-bg: {{ bg_color }}; --bb-vs-brand: {{ brand_color }}; --bb-vs-accent: {{ accent_red }};"
>
  <div class="bb-vs-table__inner">
    {%- if section.settings.section_title != blank -%}
      <h2 class="bb-vs-table__title">
        {{ section.settings.section_title | replace: 'Bounty', '<span class="bb-vs-table__brand">Bounty</span>' | replace: 'Generic', '<span class="bb-vs-table__generic">Generic</span>' }}
      </h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="bb-vs-table__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    <div class="bb-vs-table__column-headers">
      <div class="bb-vs-table__col-header bb-vs-table__col-header--us">
        <span>{{ section.settings.us_column_label | default: 'The Bounty Basket Co.' | escape }}</span>
      </div>
      <div class="bb-vs-table__col-header bb-vs-table__col-header--spacer" aria-hidden="true"></div>
      <div class="bb-vs-table__col-header bb-vs-table__col-header--them">
        <span>{{ section.settings.them_column_label | default: 'The Generic Gift' | escape }}</span>
      </div>
    </div>

    <div class="bb-vs-table__rows">
      {%- for i in (1..5) -%}
        {%- case i -%}
          {%- when 1 -%}
            {%- assign category_label = section.settings.category_1 -%}
            {%- assign us_icon = section.settings.us_icon_1 -%}
            {%- assign us_headline = section.settings.us_headline_1 -%}
            {%- assign us_body = section.settings.us_body_1 -%}
            {%- assign them_icon = section.settings.them_icon_1 -%}
            {%- assign them_headline = section.settings.them_headline_1 -%}
            {%- assign them_body = section.settings.them_body_1 -%}
          {%- when 2 -%}
            {%- assign category_label = section.settings.category_2 -%}
            {%- assign us_icon = section.settings.us_icon_2 -%}
            {%- assign us_headline = section.settings.us_headline_2 -%}
            {%- assign us_body = section.settings.us_body_2 -%}
            {%- assign them_icon = section.settings.them_icon_2 -%}
            {%- assign them_headline = section.settings.them_headline_2 -%}
            {%- assign them_body = section.settings.them_body_2 -%}
          {%- when 3 -%}
            {%- assign category_label = section.settings.category_3 -%}
            {%- assign us_icon = section.settings.us_icon_3 -%}
            {%- assign us_headline = section.settings.us_headline_3 -%}
            {%- assign us_body = section.settings.us_body_3 -%}
            {%- assign them_icon = section.settings.them_icon_3 -%}
            {%- assign them_headline = section.settings.them_headline_3 -%}
            {%- assign them_body = section.settings.them_body_3 -%}
          {%- when 4 -%}
            {%- assign category_label = section.settings.category_4 -%}
            {%- assign us_icon = section.settings.us_icon_4 -%}
            {%- assign us_headline = section.settings.us_headline_4 -%}
            {%- assign us_body = section.settings.us_body_4 -%}
            {%- assign them_icon = section.settings.them_icon_4 -%}
            {%- assign them_headline = section.settings.them_headline_4 -%}
            {%- assign them_body = section.settings.them_body_4 -%}
          {%- when 5 -%}
            {%- assign category_label = section.settings.category_5 -%}
            {%- assign us_icon = section.settings.us_icon_5 -%}
            {%- assign us_headline = section.settings.us_headline_5 -%}
            {%- assign us_body = section.settings.us_body_5 -%}
            {%- assign them_icon = section.settings.them_icon_5 -%}
            {%- assign them_headline = section.settings.them_headline_5 -%}
            {%- assign them_body = section.settings.them_body_5 -%}
        {%- endcase -%}

        {%- if us_headline != blank or them_headline != blank -%}
          <div class="bb-vs-table__row">
            <div class="bb-vs-table__cell bb-vs-table__cell--us">
              <div class="bb-vs-table__icon bb-vs-table__icon--us" aria-hidden="true">
                {%- render 'bb-vs-table-icon', name: us_icon, fallback: 'check-circle' -%}
              </div>
              <div class="bb-vs-table__copy">
                <h3 class="bb-vs-table__headline">{{ us_headline | escape }}</h3>
                {%- if us_body != blank -%}
                  <p class="bb-vs-table__body">{{ us_body | escape }}</p>
                {%- endif -%}
              </div>
            </div>

            <div class="bb-vs-table__category">
              <span>{{ category_label | escape }}</span>
            </div>

            <div class="bb-vs-table__cell bb-vs-table__cell--them">
              <div class="bb-vs-table__icon bb-vs-table__icon--them" aria-hidden="true">
                {%- render 'bb-vs-table-icon', name: them_icon, fallback: 'x-circle' -%}
              </div>
              <div class="bb-vs-table__copy">
                <h3 class="bb-vs-table__headline">{{ them_headline | escape }}</h3>
                {%- if them_body != blank -%}
                  <p class="bb-vs-table__body">{{ them_body | escape }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <p class="bb-vs-table__footer">{{ section.settings.footer_text | escape }}</p>
    {%- endif -%}
  </div>
</section>

