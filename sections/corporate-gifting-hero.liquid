{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --section-spacing-block: 0px;
    --hero-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-accent: {{ section.settings.accent_color.rgb }};
  }

  .corporate-hero {
    position: relative;
    overflow: hidden;
  }

  .corporate-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .corporate-hero__media img,
  .corporate-hero__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .corporate-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(var(--hero-overlay));
  }

  .corporate-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 60px 20px 0;
    color: {{ section.settings.text_color }};
    max-width: 900px;
    margin: 0 auto;
  }

  .corporate-hero__heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 16px;
  }

  .corporate-hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.6;
    margin: 0 0 32px;
    opacity: 0.9;
    max-width: 650px;
  }

  .corporate-hero__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .corporate-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    color: inherit;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: background 0.2s, border-color 0.2s;
  }

  .corporate-hero__pill:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .corporate-hero__pill svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .corporate-hero__cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    margin-bottom: 48px;
  }

  .corporate-hero__highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    width: 100%;
    max-width: 100vw;
    background: rgba(255, 255, 255, 0.1);
  }

  #shopify-section-{{ section.id }} .corporate-hero__highlights {
    max-width: none;
  }

  .corporate-hero__highlight-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 20px 24px;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(4px);
    color: {{ section.settings.text_color }};
    text-align: left;
  }

  .corporate-hero__highlight-item svg {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: rgb(var(--hero-accent));
  }

  .corporate-hero__highlight-text {
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.4;
  }

  @media screen and (max-width: 699px) {
    .corporate-hero__content {
      padding: 40px 16px 0;
    }

    .corporate-hero__highlights {
      grid-template-columns: 1fr;
    }

    .corporate-hero__pill {
      padding: 8px 16px;
      font-size: 0.8rem;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="corporate-hero">
    <div class="corporate-hero__media">
      {%- if section.settings.image != blank -%}
        {{- section.settings.image | image_url: width: section.settings.image.width | image_tag: sizes: '100vw', widths: '600,800,1000,1200,1400,1600,1800,2000,2400,2800,3200', fetchpriority: 'high' -}}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
      {%- endif -%}
    </div>

    <div class="corporate-hero__content">
      {%- if section.settings.subheading != blank -%}
        <p class="subheading" style="color: rgb(var(--hero-accent)); margin-bottom: 8px;">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="corporate-hero__heading">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="corporate-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- assign pills = section.blocks | where: 'type', 'feature_pill' -%}
      {%- if pills.size > 0 -%}
        <div class="corporate-hero__pills">
          {%- for block in pills -%}
            <a href="{{ block.settings.url | default: '#' }}" class="corporate-hero__pill" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != 'none' -%}
                {%- render 'icon' with block.settings.icon, width: 20, height: 20 -%}
              {%- endif -%}
              {{ block.settings.label | escape }}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="corporate-hero__cta-row">
        {%- if section.settings.button_1_text != blank -%}
          {%- render 'button', content: section.settings.button_1_text, href: section.settings.button_1_url, size: 'xl', style: 'fill', background: section.settings.accent_color, text_color: section.settings.button_text_color -%}
        {%- endif -%}

        {%- if section.settings.button_2_text != blank -%}
          {%- render 'button', content: section.settings.button_2_text, href: section.settings.button_2_url, size: 'xl', style: 'outline' -%}
        {%- endif -%}
      </div>
    </div>

    {%- assign highlights = section.blocks | where: 'type', 'highlight' -%}
    {%- if highlights.size > 0 -%}
      <div class="corporate-hero__highlights" style="position: relative; z-index: 1;">
        {%- for block in highlights -%}
          <div class="corporate-hero__highlight-item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != 'none' -%}
              {%- render 'icon' with block.settings.icon, width: 28, height: 28 -%}
            {%- endif -%}
            <span class="corporate-hero__highlight-text">{{ block.settings.text | escape }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

