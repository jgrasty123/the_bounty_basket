{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
BROBASKET GUARANTEE STRIP (W3-03)
----------------------------------------------------------------------------------------------------------------------

Full-width 3-statement trust strip designed for cart and collection page
placement. Pre-populated with James's three guarantee promises:
  1. 100% Satisfaction Guaranteed
  2. Hand-Made to Order in the USA
  3. Guaranteed to Arrive Looking Awesome

Why deliberately NOT placed on PDP: the existing PDP buy-box already has
a strong 4-cell trust grid (greeting card / same-day ship / future delivery
date / made in USA). Adding this strip there would dilute, not reinforce.
Cart-page placement catches buyers at the moment of commitment; collection-
page placement raises perceived trust before product selection.

Layout: 3 columns on desktop / tablet, single column stacked on mobile.
Each statement = icon + headline + 1-line description. Icons rendered
inline as SVGs (no external dependency, no font loading).
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign bg_color   = section.settings.background_color | default: '#fdf9f1' -%}
{%- assign icon_color = section.settings.icon_color       | default: '#cd241d' -%}
{%- assign compact_class = '' -%}
{%- if section.settings.compact_mode -%}
  {%- assign compact_class = ' bb-guarantee-strip--compact' -%}
{%- endif -%}

<section
  class="bb-guarantee-strip{{ compact_class }}"
  style="--bb-gs-bg: {{ bg_color }}; --bb-gs-icon: {{ icon_color }};"
>
  <div class="bb-guarantee-strip__inner">
    {%- if section.settings.section_title != blank -%}
      <h2 class="bb-guarantee-strip__title">{{ section.settings.section_title | escape }}</h2>
    {%- endif -%}

    <div class="bb-guarantee-strip__grid">
      {%- for i in (1..3) -%}
        {%- case i -%}
          {%- when 1 -%}
            {%- assign s_icon = section.settings.icon_1 -%}
            {%- assign s_headline = section.settings.headline_1 -%}
            {%- assign s_body = section.settings.body_1 -%}
          {%- when 2 -%}
            {%- assign s_icon = section.settings.icon_2 -%}
            {%- assign s_headline = section.settings.headline_2 -%}
            {%- assign s_body = section.settings.body_2 -%}
          {%- when 3 -%}
            {%- assign s_icon = section.settings.icon_3 -%}
            {%- assign s_headline = section.settings.headline_3 -%}
            {%- assign s_body = section.settings.body_3 -%}
        {%- endcase -%}

        {%- if s_headline != blank -%}
          <div class="bb-guarantee-strip__cell">
            <div class="bb-guarantee-strip__icon" aria-hidden="true">
              {%- case s_icon -%}
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path d="m9 12 2 2 4-4"/>
                  </svg>
                {%- when 'flag' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 22V4a2 2 0 0 1 2-2h11a1 1 0 0 1 .8 1.6L15 8l2.8 4.4a1 1 0 0 1-.8 1.6H6"/>
                  </svg>
                {%- when 'package' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m7.5 4.27 9 5.15"/>
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
                    <path d="M3.3 7 12 12l8.7-5"/>
                    <path d="M12 22V12"/>
                  </svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                  </svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
                  </svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 3h15v13H1zM16 8h4l3 4v5h-7V8z"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="m9 12 2 2 4-4"/>
                  </svg>
              {%- endcase -%}
            </div>
            <div class="bb-guarantee-strip__copy">
              <h3 class="bb-guarantee-strip__headline">{{ s_headline | escape }}</h3>
              {%- if s_body != blank -%}
                <p class="bb-guarantee-strip__body">{{ s_body | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee strip (W3-03)",
  "tag": "section",
  "class": "section--bb-guarantee-strip",
  "settings": [
    {
      "type": "paragraph",
      "content": "Three-statement trust strip with icons. Pre-populated with BroBasket's guarantees. Place on cart page and collection pages — already covered on PDP by the existing buy-box trust grid."
    },
    {
      "type": "checkbox",
      "id": "compact_mode",
      "label": "Compact mode",
      "default": false,
      "info": "Use on collection pages or anywhere vertical space is precious. Reduces icon size, padding, and hides body descriptions on mobile (icon + headline only). Leave off for cart and standalone placement where full impact is wanted."
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Optional heading above the strip"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#fdf9f1"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour",
      "default": "#cd241d"
    },

    { "type": "header", "content": "Statement 1" },
    {
      "type": "select",
      "id": "icon_1",
      "label": "Icon",
      "default": "shield",
      "options": [
        { "value": "shield",  "label": "Shield (guarantee)" },
        { "value": "flag",    "label": "Flag (USA)" },
        { "value": "package", "label": "Package" },
        { "value": "heart",   "label": "Heart" },
        { "value": "star",    "label": "Star" },
        { "value": "truck",   "label": "Truck" }
      ]
    },
    { "type": "text",     "id": "headline_1", "label": "Headline", "default": "100% Satisfaction Guaranteed" },
    { "type": "textarea", "id": "body_1",     "label": "Description", "default": "If you're not happy with your basket, we'll make it right." },

    { "type": "header", "content": "Statement 2" },
    {
      "type": "select",
      "id": "icon_2",
      "label": "Icon",
      "default": "flag",
      "options": [
        { "value": "shield",  "label": "Shield (guarantee)" },
        { "value": "flag",    "label": "Flag (USA)" },
        { "value": "package", "label": "Package" },
        { "value": "heart",   "label": "Heart" },
        { "value": "star",    "label": "Star" },
        { "value": "truck",   "label": "Truck" }
      ]
    },
    { "type": "text",     "id": "headline_2", "label": "Headline", "default": "Hand-Made to Order in the USA" },
    { "type": "textarea", "id": "body_2",     "label": "Description", "default": "Each basket is built fresh by our in-house team." },

    { "type": "header", "content": "Statement 3" },
    {
      "type": "select",
      "id": "icon_3",
      "label": "Icon",
      "default": "package",
      "options": [
        { "value": "shield",  "label": "Shield (guarantee)" },
        { "value": "flag",    "label": "Flag (USA)" },
        { "value": "package", "label": "Package" },
        { "value": "heart",   "label": "Heart" },
        { "value": "star",    "label": "Star" },
        { "value": "truck",   "label": "Truck" }
      ]
    },
    { "type": "text",     "id": "headline_3", "label": "Headline", "default": "Guaranteed to Arrive Looking Awesome" },
    { "type": "textarea", "id": "body_3",     "label": "Description", "default": "Or we'll fix it for free." }
  ],
  "presets": [
    {
      "name": "Guarantee strip (W3-03)",
      "category": "Trust signals"
    }
  ],
  "enabled_on": {
    "templates": ["cart", "collection", "product", "index", "page"]
  }
}
{% endschema %}
