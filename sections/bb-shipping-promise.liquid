{% comment %}
  bb-shipping-promise.liquid
  Shipping & Guarantees trust-signal section for PDP.
  All copy is editable via theme customizer block settings.
  Layout: 2-column grid (4 items) + full-width signature info on desktop.
  Single column on mobile.
{% endcomment %}

{% liquid
  assign s = section.settings
%}

<div class="bb-shipping-promise" id="bb-shipping-promise-{{ section.id }}">
  {%- if s.heading != blank -%}
    <h3 class="bb-shipping-promise__heading">{{ s.heading }}</h3>
  {%- endif -%}

  <div class="bb-shipping-promise__grid">
    {%- if s.item1_title != blank -%}
      <div class="bb-shipping-promise__item">
        <span class="bb-shipping-promise__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7h11v10H3z"/><path d="M14 10h4l3 3v4h-7"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>
          </svg>
        </span>
        <div class="bb-shipping-promise__content">
          <strong class="bb-shipping-promise__title">{{ s.item1_title }}</strong>
          {%- if s.item1_text != blank -%}<span class="bb-shipping-promise__text">{{ s.item1_text }}</span>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if s.item2_title != blank -%}
      <div class="bb-shipping-promise__item">
        <span class="bb-shipping-promise__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>
          </svg>
        </span>
        <div class="bb-shipping-promise__content">
          <strong class="bb-shipping-promise__title">{{ s.item2_title }}</strong>
          {%- if s.item2_text != blank -%}<span class="bb-shipping-promise__text">{{ s.item2_text }}</span>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if s.item3_title != blank -%}
      <div class="bb-shipping-promise__item">
        <span class="bb-shipping-promise__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M8 3v4M16 3v4"/><path d="M8 14l2 2 4-4"/>
          </svg>
        </span>
        <div class="bb-shipping-promise__content">
          <strong class="bb-shipping-promise__title">{{ s.item3_title }}</strong>
          {%- if s.item3_text != blank -%}<span class="bb-shipping-promise__text">{{ s.item3_text }}</span>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if s.item4_title != blank -%}
      <div class="bb-shipping-promise__item">
        <span class="bb-shipping-promise__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/>
          </svg>
        </span>
        <div class="bb-shipping-promise__content">
          <strong class="bb-shipping-promise__title">{{ s.item4_title }}</strong>
          {%- if s.item4_text != blank -%}<span class="bb-shipping-promise__text">{{ s.item4_text }}</span>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if s.item5_title != blank -%}
      <div class="bb-shipping-promise__item bb-shipping-promise__item--wide">
        <span class="bb-shipping-promise__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/>
          </svg>
        </span>
        <div class="bb-shipping-promise__content">
          <strong class="bb-shipping-promise__title">{{ s.item5_title }}</strong>
          {%- if s.item5_text != blank -%}<span class="bb-shipping-promise__text">{{ s.item5_text }}</span>{%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.bb-shipping-promise {
  padding: 20px 16px;
  margin: 16px 0;
  background: #f7f5f1;
  border: 1px solid #e8e4dc;
  border-radius: 8px;
  font-family: inherit;
  color: #1a1a1a;
}

.bb-shipping-promise__heading {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0 0 16px 0;
  color: #1a1a1a;
}

.bb-shipping-promise__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

@media (min-width: 640px) {
  .bb-shipping-promise__grid {
    grid-template-columns: 1fr 1fr;
    gap: 16px 24px;
  }
  .bb-shipping-promise__item--wide {
    grid-column: 1 / -1;
    padding-top: 14px;
    border-top: 1px solid #e8e4dc;
  }
}

.bb-shipping-promise__item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  line-height: 1.4;
}

.bb-shipping-promise__icon {
  flex: 0 0 24px;
  width: 24px;
  height: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #b91c1c;
  margin-top: 1px;
}

.bb-shipping-promise__icon svg {
  width: 22px;
  height: 22px;
}

.bb-shipping-promise__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.bb-shipping-promise__title {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.3;
}

.bb-shipping-promise__text {
  font-size: 13px;
  color: #555;
  line-height: 1.4;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Shipping Promise",
  "tag": "section",
  "class": "bb-shipping-promise-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shipping & Guarantees"
    },
    {
      "type": "header",
      "content": "Item 1 (Same-day shipping)"
    },
    {
      "type": "text",
      "id": "item1_title",
      "label": "Title",
      "default": "Same-day shipping"
    },
    {
      "type": "text",
      "id": "item1_text",
      "label": "Description",
      "default": "Order by 2pm PT (5pm ET), Mon-Fri"
    },
    {
      "type": "header",
      "content": "Item 2 (Express)"
    },
    {
      "type": "text",
      "id": "item2_title",
      "label": "Title",
      "default": "Need it tomorrow?"
    },
    {
      "type": "text",
      "id": "item2_text",
      "label": "Description",
      "default": "Express options available at checkout"
    },
    {
      "type": "header",
      "content": "Item 3 (Delivery date guarantee)"
    },
    {
      "type": "text",
      "id": "item3_title",
      "label": "Title",
      "default": "Delivery date guarantee"
    },
    {
      "type": "text",
      "id": "item3_text",
      "label": "Description",
      "default": "Pick a date - we hit it or shipping is on us"
    },
    {
      "type": "header",
      "content": "Item 4 (Packaging guarantee)"
    },
    {
      "type": "text",
      "id": "item4_title",
      "label": "Title",
      "default": "Perfect packaging guarantee"
    },
    {
      "type": "text",
      "id": "item4_text",
      "label": "Description",
      "default": "Bottles arrive intact or we replace them"
    },
    {
      "type": "header",
      "content": "Item 5 (Adult signature - full width)"
    },
    {
      "type": "text",
      "id": "item5_title",
      "label": "Title",
      "default": "Adult signature required for alcohol"
    },
    {
      "type": "text",
      "id": "item5_text",
      "label": "Description",
      "default": "UPS attempts delivery 3 times - no need to be home the first try"
    }
  ],
  "presets": [
    {
      "name": "Shipping Promise"
    }
  ]
}
{% endschema %}
